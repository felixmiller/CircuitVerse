# ============================================================================
# CircuitVerse — Production Environment Template (HM University Deployment)
# ============================================================================
# Copy to .env.production and fill in all required values.
# NEVER commit .env.production to git.
#
# For each new deployment (e.g. another faculty):
#   1. Generate a new SP cert/key pair (see SAML section below)
#   2. Register the SP metadata URL with HM IT: https://<your-domain>/users/saml/metadata
#   3. Update CALLBACK_ADDRESS, POSTGRES_PASSWORD, SECRET_KEY_BASE, SP cert/key
#   4. All other SAML vars (IDP_SSO_URL, IDP_CERT) stay the same across HM deployments

# ----------------------------------------------------------------------------
# Core
# ----------------------------------------------------------------------------

# Full URL of the deployment (no trailing slash)
CALLBACK_ADDRESS=https://circuitverse.ee.hm.edu

# Rails secret key — generate with: openssl rand -hex 64
SECRET_KEY_BASE=

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------

POSTGRES_DB=circuitverse_production
POSTGRES_USER=circuitverse
POSTGRES_PASSWORD=

# Derived from the above — keep in sync
DATABASE_URL=postgres://circuitverse:<POSTGRES_PASSWORD>@db:5432/circuitverse_production

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------

REDIS_URL=redis://redis:6379/0

# ----------------------------------------------------------------------------
# File Storage
# ----------------------------------------------------------------------------

# Use "local" for disk storage (HM deployment). Use "amazon" for S3.
ACTIVE_STORAGE_SERVICE=local

# Only needed if ACTIVE_STORAGE_SERVICE=amazon:
# AWS_S3_ACCESS_KEY_ID=
# AWS_S3_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_REGION=

# ----------------------------------------------------------------------------
# SAML / Shibboleth SSO (HM München)
# ----------------------------------------------------------------------------

# HM Shibboleth IdP SSO endpoint
IDP_SSO_URL=https://sso.hm.edu/idp/profile/SAML2/Redirect/SSO

# HM IdP certificate (no -----BEGIN/END CERTIFICATE----- lines, no whitespace)
# ⚠️  Expires October 2026 — update before then (get new cert from HM IT or IdP metadata)
IDP_CERT=

# SP certificate and private key for encrypted SAML assertions.
# Generate a new pair for each deployment:
#   openssl req -x509 -newkey rsa:2048 -keyout sp_key.pem -out sp_cert.pem -days 3650 -nodes -subj "/CN=<your-domain>"
#   # Strip the -----BEGIN/END----- lines and newlines for the env vars:
#   grep -v "^-----" sp_cert.pem | tr -d '\n'
#   grep -v "^-----" sp_key.pem | tr -d '\n'
# Then register the SP with HM IT by giving them: https://<your-domain>/users/saml/metadata
SAML_SP_CERT=
SAML_SP_KEY=

# ----------------------------------------------------------------------------
# Email (via host Postfix relay — no credentials needed)
# ----------------------------------------------------------------------------
# Outgoing mail goes: container → host Postfix (host.docker.internal:25) → forwarder.ee.hm.edu → LRZ → Exchange
# The host Postfix is pre-configured as a satellite server — no SMTP credentials required here.
# noreply@circuitverse.ee.hm.edu is an alias managed by faculty IT (forwards to responsible person).

# ----------------------------------------------------------------------------
# Disabled for HM deployment (SAML-only, no OAuth)
# ----------------------------------------------------------------------------
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=
